<%- include('../partials/header') %>
<div class="container-fluid py-4">
  <%- include('../partials/flash') %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-success"><i class="fas fa-user-tie me-2"></i>จัดการพนักงาน</h2>
    <a href="/employees/new" class="btn btn-success"><i class="fas fa-plus me-2"></i>เพิ่มพนักงาน</a>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/employees">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-search"></i></span>
              <input type="text" name="search" class="form-control" placeholder="ค้นหา รหัส, ชื่อ, เบอร์..." value="<%= search %>">
            </div>
          </div>
          <div class="col-md-4">
            <select name="position" class="form-select">
              <option value="">ตำแหน่งทั้งหมด</option>
              <% ['แคชเชียร์','ผู้จัดการ','พนักงานขาย','ผู้ดูแลระบบ'].forEach(p => { %>
                <option value="<%= p %>" <%= positionFilter === p ? 'selected' : '' %>><%= p %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-success w-100">ค้นหา</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
      <h6 class="fw-bold mb-0">รายการพนักงาน (ทั้งหมด <%= total %> คน)</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-success">
          <tr>
            <th>รหัส</th><th>ชื่อ-นามสกุล</th><th>ตำแหน่ง</th>
            <th>เบอร์โทร</th><th>เงินเดือน</th><th>วันเริ่มงาน</th><th>สถานะ</th><th>จัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% employees.forEach(e => { %>
            <tr>
              <td><code><%= e.employeeId %></code></td>
              <td class="fw-semibold"><%= e.firstName %> <%= e.lastName %></td>
              <td><span class="badge bg-info text-dark"><%= e.position %></span></td>
              <td><%= e.phone %></td>
              <td>฿<%= e.salary.toLocaleString() %></td>
              <td><%= new Date(e.startDate).toLocaleDateString('th-TH') %></td>
              <td><span class="badge <%= e.status ? 'bg-success' : 'bg-secondary' %>"><%= e.status ? 'ใช้งาน' : 'พักงาน' %></span></td>
              <td>
                <a href="/employees/<%= e._id %>" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                <a href="/employees/<%= e._id %>/edit" class="btn btn-sm btn-outline-warning me-1"><i class="fas fa-edit"></i></a>
                <form action="/employees/<%= e._id %>?_method=DELETE" method="POST"
                  class="d-inline delete-form" data-name="<%= e.firstName %>">
                  <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!employees.length) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">ไม่พบพนักงาน</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&search=<%= search %>&position=<%= positionFilter %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
</div>
<script>
  document.querySelectorAll('.delete-form').forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const name = this.dataset.name;
      if (confirm('ยืนยันการลบ ' + name + '?')) {
        this.submit();
      }
    });
  });
</script>
<%- include('../partials/footer') %>