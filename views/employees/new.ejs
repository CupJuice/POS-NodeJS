<%- include('../partials/header') %>
<div class="container py-4" style="max-width:700px">
  <%- include('../partials/flash') %>
  <div class="d-flex align-items-center mb-4">
    <a href="/employees" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold text-success mb-0"><i class="fas fa-user-plus me-2"></i>เพิ่มพนักงานใหม่</h2>
  </div>
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <form action="/employees" method="POST">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">ชื่อ *</label>
            <input type="text" name="firstName" class="form-control" required value="<%= employee.firstName || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">นามสกุล *</label>
            <input type="text" name="lastName" class="form-control" required value="<%= employee.lastName || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">เบอร์โทร *</label>
            <input type="tel" name="phone" class="form-control" required value="<%= employee.phone || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">อีเมล *</label>
            <input type="email" name="email" class="form-control" required value="<%= employee.email || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">ตำแหน่ง *</label>
            <select name="position" class="form-select" required>
              <option value="">-- เลือกตำแหน่ง --</option>
              <% ['แคชเชียร์','ผู้จัดการ','พนักงานขาย','ผู้ดูแลระบบ'].forEach(p => { %>
                <option value="<%= p %>" <%= employee.position === p ? 'selected' : '' %>><%= p %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">เงินเดือน (บาท) *</label>
            <input type="number" name="salary" class="form-control" required min="0" value="<%= employee.salary || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">วันเริ่มงาน</label>
            <input type="date" name="startDate" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>">
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">รหัสผ่าน *</label>
            <div class="input-group">
              <input type="password" name="pin" id="newPassword" class="form-control"
                required minlength="6" placeholder="อย่างน้อย 6 ตัวอักษร">
              <button type="button" class="btn btn-outline-secondary" onclick="togglePass()">
                <i class="fas fa-eye" id="eyeIcon"></i>
              </button>
            </div>
            <small class="text-muted">อย่างน้อย 6 ตัวอักษร</small>
          </div>
          <div class="col-12 text-end">
            <a href="/employees" class="btn btn-outline-secondary me-2">ยกเลิก</a>
            <button type="submit" class="btn btn-success px-4">
              <i class="fas fa-save me-2"></i>บันทึก
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function togglePass() {
    const input = document.getElementById('newPassword');
    const icon  = document.getElementById('eyeIcon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.className = 'fas fa-eye-slash';
    } else {
      input.type = 'password';
      icon.className = 'fas fa-eye';
    }
  }
</script>

<%- include('../partials/footer') %>