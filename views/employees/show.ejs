<%- include('../partials/header') %>
<div class="container py-4">
  <div class="d-flex align-items-center mb-4">
    <a href="/employees" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold text-success mb-0"><i class="fas fa-user-tie me-2"></i>ข้อมูลพนักงาน</h2>
  </div>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm text-center">
        <div class="card-body py-4">
          <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center mx-auto mb-3"
               style="width:80px;height:80px;font-size:2rem">
            <%= employee.firstName.charAt(0).toUpperCase() %>
          </div>
          <h4 class="fw-bold"><%= employee.firstName %> <%= employee.lastName %></h4>
          <p class="text-muted"><%= employee.employeeId %></p>
          <span class="badge bg-info text-dark fs-6"><%= employee.position %></span>
          <hr>
          <div class="text-center">
            <p class="mb-0 fw-bold text-success fs-5"><%= salesCount %></p>
            <small class="text-muted">รายการขายทั้งหมด</small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0">ข้อมูลส่วนตัว</h6>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="text-muted small">เบอร์โทร</label><p class="fw-semibold"><%= employee.phone %></p></div>
            <div class="col-md-6"><label class="text-muted small">อีเมล</label><p class="fw-semibold"><%= employee.email || '-' %></p></div>
            <div class="col-md-6"><label class="text-muted small">เงินเดือน</label><p class="fw-semibold text-success">฿<%= employee.salary.toLocaleString() %></p></div>
            <div class="col-md-6"><label class="text-muted small">วันเริ่มงาน</label><p class="fw-semibold"><%= new Date(employee.startDate).toLocaleDateString('th-TH') %></p></div>
            <div class="col-md-6">
              <label class="text-muted small">สถานะ</label>
              <p><span class="badge <%= employee.status ? 'bg-success' : 'bg-secondary' %>"><%= employee.status ? 'ใช้งาน' : 'พักงาน' %></span></p>
            </div>
          </div>
        </div>
      </div>
      <div class="text-end mt-3">
        <a href="/employees/<%= employee._id %>/edit" class="btn btn-warning"><i class="fas fa-edit me-2"></i>แก้ไข</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>