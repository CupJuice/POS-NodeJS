<%- include('partials/header') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<div class="container-fluid py-4">
  <%- include('partials/flash') %>

  <div class="row mb-4">
    <div class="col-12">
      <h2 class="fw-bold text-primary"><i class="fas fa-tachometer-alt me-2"></i>แดชบอร์ด</h2>
      <p class="text-muted">ภาพรวมระบบ POS วันที่ <%= new Date().toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric'}) %></p>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm bg-primary text-white h-100">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">ยอดขายวันนี้</p>
            <h3 class="fw-bold mb-0">฿<%= todaySales.total.toLocaleString('th-TH', {minimumFractionDigits:2}) %></h3>
            <small class="opacity-75"><%= todaySales.count %> รายการ</small>
          </div>
          <div class="ms-3"><i class="fas fa-chart-line fa-3x opacity-50"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm bg-success text-white h-100">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">สินค้าทั้งหมด</p>
            <h3 class="fw-bold mb-0"><%= totalProducts %></h3>
            <small class="opacity-75">รายการสินค้า</small>
          </div>
          <div class="ms-3"><i class="fas fa-box fa-3x opacity-50"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm bg-info text-white h-100">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">สมาชิกทั้งหมด</p>
            <h3 class="fw-bold mb-0"><%= totalMembers %></h3>
            <small class="opacity-75">สมาชิกที่ใช้งาน</small>
          </div>
          <div class="ms-3"><i class="fas fa-users fa-3x opacity-50"></i></div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm bg-warning text-dark h-100">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">พนักงาน</p>
            <h3 class="fw-bold mb-0"><%= totalEmployees %></h3>
            <small class="opacity-75">คน</small>
          </div>
          <div class="ms-3"><i class="fas fa-user-tie fa-3x opacity-50"></i></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-12"><h5 class="fw-bold">การดำเนินการด่วน</h5></div>
    <div class="col-auto">
      <a href="/sales/pos" class="btn btn-lg btn-primary">
        <i class="fas fa-cash-register me-2"></i>เปิดหน้าขาย POS
      </a>
    </div>
    <div class="col-auto"><a href="/products" class="btn btn-lg btn-outline-success"><i class="fas fa-box-open me-2"></i>สินค้า</a></div>
    <div class="col-auto"><a href="/members" class="btn btn-lg btn-outline-info"><i class="fas fa-users me-2"></i>สมาชิก</a></div>
    <div class="col-auto"><a href="/employees" class="btn btn-lg btn-outline-warning"><i class="fas fa-user-tie me-2"></i>พนักงาน</a></div>
    <div class="col-auto"><a href="/reports" class="btn btn-lg btn-outline-secondary"><i class="fas fa-file-alt me-2"></i>รายงาน</a></div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white border-0 pt-3">
          <h6 class="fw-bold mb-0"><i class="fas fa-chart-bar me-2 text-primary"></i>ยอดขาย 6 เดือนล่าสุด</h6>
        </div>
        <div class="card-body">
          <canvas id="salesChart" height="100"></canvas>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white border-0 pt-3">
          <h6 class="fw-bold mb-0"><i class="fas fa-exclamation-triangle me-2 text-warning"></i>สินค้าใกล้หมด</h6>
        </div>
        <div class="card-body p-0">
          <% if (lowStockProducts.length === 0) { %>
            <div class="text-center py-4 text-muted">
              <i class="fas fa-check-circle fa-2x mb-2 text-success d-block"></i>สต็อกสินค้าปกติ
            </div>
          <% } else { %>
            <ul class="list-group list-group-flush">
              <% lowStockProducts.forEach(p => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <div>
                    <span class="fw-semibold"><%= p.name %></span><br>
                    <small class="text-muted"><%= p.productId %></small>
                  </div>
                  <span class="badge bg-<%= p.stock === 0 ? 'danger' : 'warning text-dark' %>">
                    <%= p.stock %> <%= p.unit %>
                  </span>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
        <div class="card-footer bg-white border-0">
          <a href="/products" class="btn btn-sm btn-outline-warning w-100">ดูทั้งหมด</a>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-3">
          <h6 class="fw-bold mb-0"><i class="fas fa-receipt me-2 text-info"></i>รายการขายล่าสุด</h6>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr><th>เลขที่</th><th>วันที่</th><th>พนักงาน</th><th>ยอดรวม</th><th>สถานะ</th><th></th></tr>
            </thead>
            <tbody>
              <% recentSales.forEach(sale => { %>
                <tr>
                  <td><code><%= sale.saleNumber %></code></td>
                  <td><%= new Date(sale.saleDate).toLocaleString('th-TH') %></td>
                  <td><%= sale.employee ? sale.employee.firstName + ' ' + sale.employee.lastName : '-' %></td>
                  <td class="fw-bold text-success">฿<%= sale.totalAmount.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
                  <td>
                    <span class="badge bg-<%= sale.status === 'completed' ? 'success' : sale.status === 'cancelled' ? 'danger' : 'warning' %>">
                      <%= sale.status === 'completed' ? 'สำเร็จ' : sale.status === 'cancelled' ? 'ยกเลิก' : 'รอชำระ' %>
                    </span>
                  </td>
                  <td><a href="/sales/<%= sale._id %>" class="btn btn-sm btn-outline-primary">ดูรายละเอียด</a></td>
                </tr>
              <% }) %>
              <% if (recentSales.length === 0) { %>
                <tr><td colspan="6" class="text-center text-muted py-3">ยังไม่มีรายการขาย</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const monthlySalesData = <%- monthlySales %>;
const months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
const labels = monthlySalesData.map(d => months[d._id.month - 1] + ' ' + (d._id.year + 543));
const data = monthlySalesData.map(d => d.total);

new Chart(document.getElementById('salesChart'), {
  type: 'bar',
  data: {
    labels,
    datasets: [{
      label: 'ยอดขาย (บาท)',
      data,
      backgroundColor: 'rgba(13, 110, 253, 0.7)',
      borderColor: 'rgba(13, 110, 253, 1)',
      borderWidth: 2,
      borderRadius: 6
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: { y: { beginAtZero: true, ticks: { callback: v => '฿' + v.toLocaleString('th-TH') } } }
  }
});
</script>

<%- include('partials/footer') %>