<%- include('../partials/header') %>
<div class="container-fluid py-4">
  <%- include('../partials/flash') %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-danger"><i class="fas fa-credit-card me-2"></i>ประวัติการชำระเงิน</h2>
    <div class="alert alert-success py-2 mb-0">
      <i class="fas fa-coins me-2"></i>รายรับรวม:
      <strong>฿<%= totalRevenue.toLocaleString('th-TH', {minimumFractionDigits:2}) %></strong>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/payments">
        <div class="row g-3">
          <div class="col-md-4">
            <input type="date" name="dateFrom" class="form-control" value="<%= dateFrom %>">
          </div>
          <div class="col-md-4">
            <input type="date" name="dateTo" class="form-control" value="<%= dateTo %>">
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn btn-danger me-2">ค้นหา</button>
            <a href="/payments" class="btn btn-outline-secondary">รีเซ็ต</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
      <h6 class="fw-bold mb-0">รายการชำระเงิน (<%= total %> รายการ)</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-danger">
          <tr>
            <th>เลขที่ชำระ</th><th>เลขที่บิล</th><th>วันที่</th>
            <th>พนักงาน</th><th>วิธีชำระ</th><th>ยอด</th><th>สถานะ</th><th>จัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(p => { %>
            <tr>
              <td><code><%= p.paymentNumber %></code></td>
              <td><a href="/sales/<%= p.sale._id %>"><code><%= p.saleNumber %></code></a></td>
              <td><%= new Date(p.paymentDate).toLocaleString('th-TH') %></td>
              <td><%= p.sale.employee ? p.sale.employee.firstName : '-' %></td>
              <td>
                <% p.paymentMethods.forEach(pm => { %>
                  <span class="badge bg-info text-dark me-1">
                    <%= {cash:'เงินสด', credit_card:'บัตรเครดิต', debit_card:'บัตรเดบิต', qr_promptpay:'QR'}[pm.method] %>
                  </span>
                <% }) %>
              </td>
              <td class="fw-bold text-success">฿<%= p.totalAmount.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
              <td>
                <span class="badge bg-<%= p.status === 'completed' ? 'success' : p.status === 'refunded' ? 'danger' : 'warning' %>">
                  <%= p.status === 'completed' ? 'สำเร็จ' : p.status === 'refunded' ? 'คืนเงิน' : 'บางส่วน' %>
                </span>
              </td>
              <td>
                <% if (p.status === 'completed') { %>
                  <form action="/payments/<%= p._id %>/refund" method="POST" class="d-inline"
                    onsubmit="return confirm('ยืนยันการคืนเงิน?')">
                    <button class="btn btn-sm btn-outline-danger">
                      <i class="fas fa-undo me-1"></i>คืนเงิน
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (!payments.length) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">ไม่พบรายการ</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>