<%- include('../partials/header') %>
<div class="container-fluid py-4">
  <%- include('../partials/flash') %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-warning"><i class="fas fa-box-open me-2"></i>จัดการสินค้า</h2>
    <a href="/products/new" class="btn btn-warning"><i class="fas fa-plus me-2"></i>เพิ่มสินค้า</a>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/products">
        <div class="row g-3">
          <div class="col-md-4">
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-search"></i></span>
              <input type="text" name="search" class="form-control" placeholder="ค้นหา รหัส, ชื่อ, บาร์โค้ด..." value="<%= search %>">
            </div>
          </div>
          <div class="col-md-3">
            <select name="category" class="form-select">
              <option value="">หมวดหมู่ทั้งหมด</option>
              <% categories.forEach(c => { %>
                <option value="<%= c %>" <%= categoryFilter === c ? 'selected' : '' %>><%= c %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <select name="lowstock" class="form-select">
              <option value="">สต็อกทั้งหมด</option>
              <option value="true" <%= lowstockFilter === 'true' ? 'selected' : '' %>>สต็อกน้อย</option>
            </select>
          </div>
          <div class="col-md-3">
            <button type="submit" class="btn btn-warning me-2">ค้นหา</button>
            <a href="/products" class="btn btn-outline-secondary">รีเซ็ต</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
      <h6 class="fw-bold mb-0">รายการสินค้า (ทั้งหมด <%= total %> รายการ)</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-warning">
          <tr>
            <th>รหัส</th><th>ชื่อสินค้า</th><th>หมวดหมู่</th>
            <th>ราคาทุน</th><th>ราคาขาย</th><th>สต็อก</th><th>สถานะ</th><th>จัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr class="<%= p.stock <= p.minStock ? 'table-danger' : '' %>">
              <td><code><%= p.productId %></code></td>
              <td class="fw-semibold">
                <%= p.name %>
                <% if (p.stock <= p.minStock) { %>
                  <span class="badge bg-danger ms-1">สต็อกน้อย</span>
                <% } %>
              </td>
              <td><span class="badge bg-light text-dark border"><%= p.category %></span></td>
              <td>฿<%= p.costPrice.toLocaleString() %></td>
              <td class="fw-bold text-success">฿<%= p.sellPrice.toLocaleString() %></td>
              <td>
                <span class="fw-bold <%= p.stock === 0 ? 'text-danger' : p.stock <= p.minStock ? 'text-warning' : 'text-success' %>">
                  <%= p.stock %> <%= p.unit %>
                </span>
              </td>
              <td><span class="badge <%= p.status ? 'bg-success' : 'bg-secondary' %>"><%= p.status ? 'ขาย' : 'หยุดขาย' %></span></td>
              <td>
                <a href="/products/<%= p._id %>/edit" class="btn btn-sm btn-outline-warning me-1"><i class="fas fa-edit"></i></a>
                <button class="btn btn-sm btn-outline-info me-1" 
                  data-id="<%= p._id %>" 
                  data-name="<%= p.name %>" 
                  data-stock="<%= p.stock %>"
                  onclick="showStockModal(this.dataset.id, this.dataset.name, parseInt(this.dataset.stock))">
                  <i class="fas fa-boxes"></i>
                </button>
                <form action="/products/<%= p._id %>?_method=DELETE" method="POST" 
                  class="d-inline delete-form" data-name="<%= p.name %>">
                  <button class="btn btn-sm btn-outline-danger" title="ลบสินค้า">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!products.length) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">ไม่พบสินค้า</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&search=<%= search %>&category=<%= categoryFilter %>&lowstock=<%= lowstockFilter %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
</div>

<!-- Stock Adjustment Modal -->
<div class="modal fade" id="stockModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-info text-white">
        <h5 class="modal-title"><i class="fas fa-boxes me-2"></i>ปรับสต็อกสินค้า</h5>
        <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="stockForm" method="POST">
        <div class="modal-body">

          <!-- ชื่อสินค้าและสต็อกปัจจุบัน -->
          <div class="alert alert-light border mb-3">
            <div class="fw-bold fs-6" id="stockProductName"></div>
            <div class="d-flex justify-content-between mt-1">
              <span class="text-muted small">สต็อกปัจจุบัน</span>
              <span class="fw-bold text-primary" id="currentStockDisplay"></span>
            </div>
          </div>

          <!-- เลือกประเภทการปรับ -->
          <div class="mb-3">
            <label class="form-label fw-semibold">ประเภทการปรับ</label>
            <div class="row g-2">
              <div class="col-6">
                <input type="radio" class="btn-check" name="adjustType" id="typeAdd" value="add" checked>
                <label class="btn btn-outline-success w-100" for="typeAdd">
                  <i class="fas fa-plus me-2"></i>เพิ่มสต็อก
                </label>
              </div>
              <div class="col-6">
                <input type="radio" class="btn-check" name="adjustType" id="typeRemove" value="remove">
                <label class="btn btn-outline-danger w-100" for="typeRemove">
                  <i class="fas fa-minus me-2"></i>ลดสต็อก
                </label>
              </div>
            </div>
          </div>

          <!-- จำนวน -->
          <div class="mb-3">
            <label class="form-label fw-semibold">จำนวน</label>
            <div class="input-group">
              <button type="button" class="btn btn-outline-secondary" onclick="changeAmount(-1)">-</button>
              <input type="number" id="adjustAmount" class="form-control text-center fw-bold fs-5"
                min="1" value="1" oninput="updatePreview()">
              <button type="button" class="btn btn-outline-secondary" onclick="changeAmount(1)">+</button>
            </div>
            <input type="hidden" name="adjustment" id="finalAdjustment">
          </div>

          <!-- preview ผลลัพธ์ -->
          <div class="alert alert-warning mb-0">
            <div class="d-flex justify-content-between">
              <span>สต็อกหลังปรับ</span>
              <span class="fw-bold fs-5" id="stockPreview">-</span>
            </div>
          </div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-info px-4" onclick="return prepareSubmit()">
            <i class="fas fa-save me-2"></i>บันทึก
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
let currentStockValue = 0;

function showStockModal(id, name, stock) {
  currentStockValue = stock;
  document.getElementById('stockProductName').textContent = name;
  document.getElementById('currentStockDisplay').textContent = stock + ' ชิ้น';
  document.getElementById('adjustAmount').value = 1;
  document.getElementById('typeAdd').checked = true;
  document.getElementById('stockForm').action = `/products/${id}/stock`;
  updatePreview();
  new bootstrap.Modal(document.getElementById('stockModal')).show();
}

function changeAmount(delta) {
  const input = document.getElementById('adjustAmount');
  const val = parseInt(input.value) || 1;
  input.value = Math.max(1, val + delta);
  updatePreview();
}

function updatePreview() {
  const amount = parseInt(document.getElementById('adjustAmount').value) || 0;
  const isAdd = document.getElementById('typeAdd').checked;
  const result = isAdd ? currentStockValue + amount : Math.max(0, currentStockValue - amount);
  document.getElementById('stockPreview').textContent = result + ' ชิ้น';
  document.getElementById('stockPreview').className = 'fw-bold fs-5 ' + (result <= 0 ? 'text-danger' : 'text-success');
}

function prepareSubmit() {
  const amount = parseInt(document.getElementById('adjustAmount').value) || 0;
  if (amount <= 0) { alert('กรุณากรอกจำนวนที่ถูกต้อง'); return false; }
  const isAdd = document.getElementById('typeAdd').checked;
  document.getElementById('finalAdjustment').value = isAdd ? amount : -amount;
  return true;
}

// อัพเดท preview เมื่อเปลี่ยนประเภท
document.querySelectorAll('input[name="adjustType"]').forEach(r => {
  r.addEventListener('change', updatePreview);
});

// delete confirm
  document.querySelectorAll('.delete-form').forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const name = this.dataset.name;
      if (confirm('ลบ ' + name + ' ออกจากระบบ?')) {
        this.submit();
      }
    });
  });
</script>
<%- include('../partials/footer') %>