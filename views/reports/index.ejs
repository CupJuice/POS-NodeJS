<%- include('../partials/header') %>
<div class="container py-4">
  <h2 class="fw-bold text-secondary mb-4"><i class="fas fa-chart-bar me-2"></i>รายงาน</h2>
  <div class="row g-4">
    <div class="col-md-6 col-lg-3">
      <a href="/reports/daily" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 card-hover">
          <div class="card-body text-center py-4">
            <div class="rounded-circle bg-primary bg-opacity-10 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:70px;height:70px">
              <i class="fas fa-calendar-day fa-2x text-primary"></i>
            </div>
            <h6 class="fw-bold text-dark">รายงานรายวัน</h6>
            <p class="text-muted small mb-0">ยอดขาย กำไร แยกตามชั่วโมง</p>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/reports/monthly" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 card-hover">
          <div class="card-body text-center py-4">
            <div class="rounded-circle bg-success bg-opacity-10 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:70px;height:70px">
              <i class="fas fa-calendar-alt fa-2x text-success"></i>
            </div>
            <h6 class="fw-bold text-dark">รายงานรายเดือน</h6>
            <p class="text-muted small mb-0">ยอดขายประจำเดือน เปรียบเทียบ</p>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/reports/products" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 card-hover">
          <div class="card-body text-center py-4">
            <div class="rounded-circle bg-warning bg-opacity-10 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:70px;height:70px">
              <i class="fas fa-box fa-2x text-warning"></i>
            </div>
            <h6 class="fw-bold text-dark">รายงานสินค้า</h6>
            <p class="text-muted small mb-0">สินค้าขายดี สต็อก กำไร</p>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-6 col-lg-3">
      <a href="/reports/members" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 card-hover">
          <div class="card-body text-center py-4">
            <div class="rounded-circle bg-info bg-opacity-10 mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:70px;height:70px">
              <i class="fas fa-users fa-2x text-info"></i>
            </div>
            <h6 class="fw-bold text-dark">รายงานสมาชิก</h6>
            <p class="text-muted small mb-0">ลูกค้าชั้นนำ แต้มสะสม</p>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>