<%- include('../partials/header') %>
<div class="container-fluid py-4">
  <div class="d-flex align-items-center mb-4">
    <a href="/reports" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold text-info mb-0"><i class="fas fa-users me-2"></i>รายงานสมาชิก</h2>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm bg-info text-white">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">สมาชิกทั้งหมด</p>
            <h3 class="fw-bold"><%= totalMembers %> คน</h3>
          </div>
          <i class="fas fa-users fa-3x opacity-50"></i>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm bg-primary text-white">
        <div class="card-body d-flex align-items-center">
          <div class="flex-grow-1">
            <p class="mb-1 opacity-75">สมาชิกใหม่เดือนนี้</p>
            <h3 class="fw-bold"><%= newMembersThisMonth %> คน</h3>
          </div>
          <i class="fas fa-user-plus fa-3x opacity-50"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0">ลูกค้าชั้นนำ Top 10</h6>
        </div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead class="table-light">
              <tr><th>#</th><th>สมาชิก</th><th>รหัส</th><th>ออเดอร์</th><th>ยอดใช้จ่าย</th></tr>
            </thead>
            <tbody>
              <% topMembers.forEach((m, i) => { %>
                <tr>
                  <td><span class="badge bg-info"><%= i+1 %></span></td>
                  <td><a href="/members/<%= m._id %>"><%= m.memberData.firstName %> <%= m.memberData.lastName %></a></td>
                  <td><code><%= m.memberData.memberId %></code></td>
                  <td><%= m.orderCount %></td>
                  <td class="fw-bold text-success">฿<%= m.totalSpent.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
                </tr>
              <% }) %>
              <% if (!topMembers.length) { %>
                <tr><td colspan="5" class="text-center text-muted py-3">ยังไม่มีข้อมูล</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0">สัดส่วนระดับสมาชิก</h6>
        </div>
        <div class="card-body d-flex align-items-center justify-content-center">
          <canvas id="levelChart" height="200"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const levelData = <%- levelStats %>;
const levelColors = {
  Bronze: '#dc3545',
  Silver: '#6c757d',
  Gold: '#ffc107',
  Platinum: '#343a40'
};
new Chart(document.getElementById('levelChart'), {
  type: 'pie',
  data: {
    labels: levelData.map(l => l._id),
    datasets: [{
      data: levelData.map(l => l.count),
      backgroundColor: levelData.map(l => levelColors[l._id] || '#0d6efd')
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { position: 'bottom' } }
  }
});
</script>
<%- include('../partials/footer') %>