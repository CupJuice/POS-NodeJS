<%- include('../partials/header') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<div class="container-fluid py-4">
  <div class="d-flex align-items-center mb-4">
    <a href="/reports" class="btn btn-outline-secondary me-3"><i class="fas fa-arrow-left"></i></a>
    <h2 class="fw-bold text-warning mb-0"><i class="fas fa-box me-2"></i>รายงานสินค้า</h2>
  </div>
  <div class="row g-4">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0">สินค้าขายดี Top 10</h6>
        </div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead class="table-light">
              <tr><th>#</th><th>สินค้า</th><th>จำนวน</th><th>ยอดขาย</th></tr>
            </thead>
            <tbody>
              <% topSellingProducts.forEach((p,i) => { %>
                <tr>
                  <td><span class="badge bg-warning text-dark"><%= i+1 %></span></td>
                  <td class="fw-semibold"><%= p.name %></td>
                  <td><%= p.totalQty %></td>
                  <td class="text-success fw-bold">฿<%= p.totalRevenue.toLocaleString() %></td>
                </tr>
              <% }) %>
              <% if (!topSellingProducts.length) { %>
                <tr><td colspan="4" class="text-center text-muted py-3">ไม่มีข้อมูล</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0 text-danger"><i class="fas fa-exclamation-triangle me-2"></i>สินค้าสต็อกต่ำ</h6>
        </div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead class="table-light">
              <tr><th>รหัส</th><th>สินค้า</th><th>สต็อก</th><th>ขั้นต่ำ</th></tr>
            </thead>
            <tbody>
              <% lowStockProducts.forEach(p => { %>
                <tr class="<%= p.stock === 0 ? 'table-danger' : 'table-warning' %>">
                  <td><code><%= p.productId %></code></td>
                  <td><a href="/products/<%= p._id %>/edit"><%= p.name %></a></td>
                  <td>
                    <span class="fw-bold <%= p.stock === 0 ? 'text-danger' : 'text-warning' %>">
                      <%= p.stock %>
                    </span>
                  </td>
                  <td><%= p.minStock %></td>
                </tr>
              <% }) %>
              <% if (!lowStockProducts.length) { %>
                <tr><td colspan="4" class="text-center text-success py-3">
                  <i class="fas fa-check-circle me-2"></i>สต็อกปกติทุกรายการ
                </td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white">
          <h6 class="fw-bold mb-0">ยอดขายแยกหมวดหมู่</h6>
        </div>
        <div class="card-body d-flex align-items-center justify-content-center">
          <canvas id="catChart"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const catData = <%- categoryStats %>;
new Chart(document.getElementById('catChart'), {
  type: 'doughnut',
  data: {
    labels: catData.map(c => c._id || 'ไม่ระบุ'),
    datasets: [{
      data: catData.map(c => c.totalRevenue),
      backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#0dcaf0','#6f42c1','#fd7e14']
    }]
  },
  options: {
    responsive: true,
    plugins: { legend: { position: 'bottom' } }
  }
});
</script>
<%- include('../partials/footer') %>