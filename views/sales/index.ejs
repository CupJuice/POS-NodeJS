<%- include('../partials/header') %>
<div class="container-fluid py-4">
  <%- include('../partials/flash') %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-info"><i class="fas fa-receipt me-2"></i>รายการขาย</h2>
    <a href="/sales/pos" class="btn btn-primary"><i class="fas fa-cash-register me-2"></i>เปิดหน้าขาย</a>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/sales">
        <div class="row g-3">
          <div class="col-md-3">
            <input type="text" name="search" class="form-control" placeholder="ค้นหาเลขที่..." value="<%= search %>">
          </div>
          <div class="col-md-2">
            <select name="status" class="form-select">
              <option value="">สถานะทั้งหมด</option>
              <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>รอชำระ</option>
              <option value="completed" <%= statusFilter === 'completed' ? 'selected' : '' %>>สำเร็จ</option>
              <option value="cancelled" <%= statusFilter === 'cancelled' ? 'selected' : '' %>>ยกเลิก</option>
              <option value="refunded" <%= statusFilter === 'refunded' ? 'selected' : '' %>>คืนเงิน</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="date" name="dateFrom" class="form-control" value="<%= dateFrom %>">
          </div>
          <div class="col-md-2">
            <input type="date" name="dateTo" class="form-control" value="<%= dateTo %>">
          </div>
          <div class="col-md-3">
            <button type="submit" class="btn btn-info me-2">ค้นหา</button>
            <a href="/sales" class="btn btn-outline-secondary">รีเซ็ต</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
      <h6 class="fw-bold mb-0">รายการขายทั้งหมด (<%= total %> รายการ)</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-info">
          <tr>
            <th>เลขที่</th><th>วันที่/เวลา</th><th>พนักงาน</th>
            <th>สมาชิก</th><th>รายการ</th><th>ยอดสุทธิ</th><th>สถานะ</th><th>จัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% sales.forEach(s => { %>
            <tr>
              <td><code><%= s.saleNumber %></code></td>
              <td><%= new Date(s.saleDate).toLocaleString('th-TH') %></td>
              <td><%= s.employee ? s.employee.firstName + ' ' + s.employee.lastName : '-' %></td>
              <td><%= s.member ? s.member.firstName + ' ' + s.member.lastName : 'ลูกค้าทั่วไป' %></td>
              <td><span class="badge bg-secondary"><%= s.items.length %> รายการ</span></td>
              <td class="fw-bold text-primary">฿<%= s.totalAmount.toLocaleString('th-TH', {minimumFractionDigits:2}) %></td>
              <td>
                <span class="badge bg-<%=
                  s.status === 'completed' ? 'success' :
                  s.status === 'cancelled' ? 'danger' :
                  s.status === 'refunded' ? 'secondary' : 'warning' %>">
                  <%= s.status === 'completed' ? 'สำเร็จ' :
                      s.status === 'cancelled' ? 'ยกเลิก' :
                      s.status === 'refunded' ? 'คืนเงิน' : 'รอชำระ' %>
                </span>
              </td>
              <td>
                <a href="/sales/<%= s._id %>" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                <% if (s.status === 'pending') { %>
                  <form action="/sales/<%= s._id %>/cancel?_method=PUT" method="POST" class="d-inline"
                    onsubmit="return confirm('ยืนยันการยกเลิกรายการ?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-times"></i></button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (!sales.length) { %>
            <tr><td colspan="8" class="text-center text-muted py-4">ไม่พบรายการขาย</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= i === currentPage ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&search=<%= search %>&status=<%= statusFilter %>&dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>